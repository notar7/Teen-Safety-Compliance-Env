# ─────────────────────────────────────────────────────────────
# Teen Safety Compliance Environment — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit your .env file to GitHub!
# ─────────────────────────────────────────────────────────────

# LLM API endpoint (Groq is free and recommended)
# Groq:   https://api.groq.com/openai/v1
# OpenAI: https://api.openai.com/v1
API_BASE_URL=https://api.groq.com/openai/v1

# Model to use for inference
# Groq (free):  llama-3.3-70b-versatile
# OpenAI (paid): gpt-4o-mini
MODEL_NAME=llama-3.3-70b-versatile

# Your API key — get free Groq key at https://console.groq.com
OPENAI_API_KEY=your_groq_or_openai_key_here

# HuggingFace token — needed for deployment to HF Spaces
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here
